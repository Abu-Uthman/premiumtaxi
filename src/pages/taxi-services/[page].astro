---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import heroImg from '../../assets/van-exterior-1.jpeg';
import interiorImg from '../../assets/van-interior-1.jpeg';
import servicesData from '../../data/services.json';
import locationsData from '../../data/locations.js';
import priorityPagesData from '../../data/priorityPages.json';

export async function getStaticPaths() {
  return priorityPagesData.map((page) => ({
    params: { page: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const service = servicesData.find((item) => item.slug === page.primaryServiceSlug) || servicesData[0];
const pageLocations = page.locationSlugs
  .map((slug) => locationsData.find((loc) => loc.slug === slug))
  .filter(Boolean);
const primaryLocation = pageLocations[0];
const relatedServices = servicesData.filter((item) => item.slug !== service.slug).slice(0, 5);
const relatedLocations = primaryLocation
  ? locationsData.filter((loc) => loc.region === primaryLocation.region && loc.slug !== primaryLocation.slug).slice(0, 6)
  : locationsData.slice(0, 6);

const canonical = new URL(Astro.url.pathname, Astro.site || 'https://premiummaxitaxi.com.au').href;
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL('/', Astro.site || 'https://premiummaxitaxi.com.au').href },
    { "@type": "ListItem", "position": 2, "name": "Taxi Services", "item": new URL('/taxi-services/', Astro.site || 'https://premiummaxitaxi.com.au').href },
    { "@type": "ListItem", "position": 3, "name": page.h1, "item": canonical }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": page.h1,
  "description": page.description,
  "serviceType": service.name,
  "provider": {
    "@type": ["LocalBusiness", "TaxiService"],
    "name": "Premium Maxi Taxi Victoria",
    "url": new URL('/', Astro.site || 'https://premiummaxitaxi.com.au').href
  },
  "areaServed": pageLocations.map((loc) => ({
    "@type": "City",
    "name": loc.name
  })),
  "url": canonical
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": page.faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<Layout title={page.title} description={page.description}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main>
    <section class="priority-hero">
      <div class="priority-hero-bg">
        <Image src={heroImg} alt={`${page.h1} taxi service Melbourne Victoria`} width={1920} height={760} class="hero-img" loading="eager" quality={68} />
        <div class="hero-overlay"></div>
      </div>
      <div class="container hero-content">
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/services">Services</a>
          <span>/</span>
          <span>{page.h1}</span>
        </nav>
        <span class="badge">Pre-booked Melbourne taxi service</span>
        <h1>{page.h1}</h1>
        <p>{page.description}</p>
        <div class="hero-actions">
          <a href="/book" class="btn btn-primary">Book Now</a>
          <a href="tel:+61432405388" class="btn btn-ghost">Call</a>
          <a href="/contact" class="btn btn-ghost">Get Quote</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container landing-grid">
        <article>
          <div class="section-tag">Local Booking Page</div>
          <h2>{page.h1} for Real Passenger Needs</h2>
          <p>{page.localNotes}</p>
          <p>
            This booking page is built for passengers who need the right taxi type before pickup: maxi cab space, standard taxi convenience, SUV or wagon luggage room, baby-seat requests, wheelchair access, parcel delivery, airport timing, event groups, or outer-suburb travel.
          </p>

          <h3>Best For</h3>
          <div class="use-case-grid">
            {page.useCases.map((item) => (
              <div class="use-card">
                <span>✓</span>
                <strong>{item}</strong>
              </div>
            ))}
          </div>

          <h3>Linked Service and Areas</h3>
          <div class="link-row">
            <a href={`/services/${service.slug}`}>{service.name}</a>
            {pageLocations.map((loc) => (
              <a href={`/locations/${loc.slug}`}>{loc.name}</a>
            ))}
          </div>
        </article>

        <aside class="booking-panel">
          <Image src={interiorImg} alt="Clean maxi taxi interior with spacious passenger seating" width={520} height={340} class="panel-img" quality={65} />
          <div class="panel-body">
            <h2>Plan the Ride Properly</h2>
            <p>Include pickup, destination, passengers, luggage, child seats, wheelchair needs, flight details, stops, and preferred time.</p>
            <a href="/book" class="btn btn-primary">Start Booking</a>
            <a href="tel:+61432405388" class="panel-call">Call +61 432 405 388</a>
          </div>
        </aside>
      </div>
    </section>

    <section class="section section-light">
      <div class="container">
        <div class="section-tag text-center">Why Pre-Book</div>
        <h2 class="section-title text-center">A Better Fit Than a Random Taxi</h2>
        <div class="trust-grid">
          <div class="trust-card"><strong>Right Vehicle</strong><p>Match the booking to passengers, luggage, child seats, wheelchair access, or group size.</p></div>
          <div class="trust-card"><strong>Clear Timing</strong><p>Early flights, school runs, appointments, events, and cruise boarding need planned pickup windows.</p></div>
          <div class="trust-card"><strong>Local Coverage</strong><p>Inner Melbourne, outer suburbs, airports, cruise terminals, regional Victoria, and day-trip routes.</p></div>
          <div class="trust-card"><strong>Simple CTAs</strong><p>Book online, call, or request a quote now; final phone and WhatsApp details can be swapped in later.</p></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container related-grid">
        <div>
          <div class="section-tag">Related Services</div>
          <h2>Other Taxi Options</h2>
          <div class="stack-links">
            {relatedServices.map((item) => (
              <a href={`/services/${item.slug}`}>{item.name}</a>
            ))}
          </div>
        </div>
        <div>
          <div class="section-tag">Nearby Coverage</div>
          <h2>Nearby Service Areas</h2>
          <div class="stack-links">
            {relatedLocations.map((loc) => (
              <a href={`/locations/${loc.slug}`}>{loc.name}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section section-light">
      <div class="container faq-wrap">
        <div class="section-tag">Common Questions</div>
        <h2>Questions About {page.h1}</h2>
        {page.faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.priority-hero {
  position: relative;
  min-height: 620px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.priority-hero-bg {
  position: absolute;
  inset: 0;
}
.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, rgba(0,0,0,0.86), rgba(0,0,0,0.5), rgba(0,0,0,0.18));
}
.hero-content {
  position: relative;
  z-index: 1;
  color: white;
  max-width: 830px;
  padding-top: 90px;
}
.breadcrumb {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
  color: rgba(255,255,255,0.72);
  font-size: 0.88rem;
}
.breadcrumb a:hover { color: var(--accent-gold); }
.badge {
  display: inline-block;
  color: var(--accent-gold);
  border: 1px solid rgba(212,175,55,0.65);
  background: rgba(212,175,55,0.16);
  border-radius: 999px;
  padding: 6px 14px;
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.hero-content h1 {
  color: white;
  font-size: clamp(2.4rem, 5vw, 4.4rem);
  line-height: 1.08;
}
.hero-content p {
  color: rgba(255,255,255,0.86);
  font-size: 1.1rem;
  max-width: 720px;
}
.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px;
}
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border: 1px solid rgba(255,255,255,0.45);
  border-radius: var(--border-radius-sm);
  color: #fff;
  font-family: var(--font-heading);
  font-weight: 600;
}
.landing-grid,
.related-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 380px;
  gap: 52px;
  align-items: start;
}
.related-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}
article h2,
.related-grid h2 {
  font-size: clamp(1.8rem, 3vw, 2.7rem);
}
article p,
.booking-panel p,
.trust-card p {
  color: var(--text-muted);
  line-height: 1.75;
}
article h3 {
  margin: 32px 0 16px;
}
.use-case-grid,
.trust-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}
.trust-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}
.use-card,
.trust-card {
  padding: 18px;
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius-sm);
  background: #fff;
  box-shadow: var(--shadow-sm);
}
.use-card {
  display: flex;
  gap: 10px;
  align-items: center;
}
.use-card span { color: var(--accent-gold); font-weight: 800; }
.link-row,
.stack-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.stack-links {
  flex-direction: column;
  align-items: stretch;
}
.link-row a,
.stack-links a {
  display: inline-flex;
  padding: 10px 14px;
  border: 1px solid var(--bg-tertiary);
  border-radius: 999px;
  color: var(--text-main);
  background: #fff;
}
.stack-links a {
  border-radius: var(--border-radius-sm);
}
.link-row a:hover,
.stack-links a:hover {
  border-color: var(--accent-gold);
  color: var(--accent-gold);
}
.booking-panel {
  position: sticky;
  top: 100px;
  overflow: hidden;
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius);
  background: var(--bg-primary);
  box-shadow: var(--shadow-md);
}
.panel-img {
  width: 100%;
  height: 240px;
  object-fit: cover;
}
.panel-body {
  padding: 24px;
}
.panel-call {
  display: inline-flex;
  margin-top: 14px;
  color: var(--accent-gold);
  font-family: var(--font-heading);
  font-weight: 600;
}
.section-title {
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  margin-bottom: 28px;
}
.section-tag {
  display: inline-block;
  color: var(--accent-gold);
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.faq-wrap {
  max-width: 860px;
}
.faq-item {
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius-sm);
  background: var(--bg-primary);
  margin-bottom: 12px;
  overflow: hidden;
}
.faq-item summary {
  padding: 18px 22px;
  cursor: pointer;
  font-family: var(--font-heading);
  font-weight: 600;
}
.faq-item p {
  padding: 0 22px 20px;
  color: var(--text-muted);
}
@media (max-width: 900px) {
  .priority-hero { min-height: 560px; }
  .landing-grid,
  .related-grid,
  .use-case-grid,
  .trust-grid { grid-template-columns: 1fr; }
  .booking-panel { position: static; }
}
</style>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import heroContact from '../assets/van-family-1.jpeg';
---

<Layout 
  title="Contact Us | Premium Maxi Taxi Melbourne 24/7"
  description="Get in touch with Premium Maxi Taxi Victoria. Call, email, or send a message for quotes, bookings, and general enquiries. We're available 24/7 across Melbourne and Victoria."
>
  <Header />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="page-hero-bg">
        <Image src={heroContact} alt="Contact Premium Maxi Taxi Melbourne 24/7 group transport" width={1920} height={600} class="page-hero-img" quality={60} />
        <div class="page-hero-overlay"></div>
      </div>
      <div class="container page-hero-content">
        <span class="badge">✦ Always Available</span>
        <h1>Get in <em class="text-gold">Touch</em></h1>
        <p>We're available 24/7 across Melbourne and all of Victoria. Reach out by phone, email, or the form below.</p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="section">
      <div class="container contact-layout">

        <!-- Contact Info -->
        <div class="contact-info">
          <div class="section-tag">Direct Contact</div>
          <h2 class="section-title" style="font-size: 2rem;">How to Reach Us</h2>

          <div class="info-cards">
            <div class="info-card">
              <div class="info-icon">📞</div>
              <div>
                <h4>Phone</h4>
                <a href="tel:+61432405388" class="info-value">+61 432 405 388</a>
                <p class="text-muted" style="font-size: 0.875rem; margin-top: 4px;">Available 24 hours, 7 days</p>
              </div>
            </div>

            <div class="info-card">
              <div class="info-icon">✉️</div>
              <div>
                <h4>Email</h4>
                <a href="mailto:booking@premiummaxitaxi.com.au" class="info-value">booking@premiummaxitaxi.com.au</a>
                <p class="text-muted" style="font-size: 0.875rem; margin-top: 4px;">We respond within 1–2 hours</p>
              </div>
            </div>

            <div class="info-card">
              <div class="info-icon">📍</div>
              <div>
                <h4>Service Area</h4>
                <span class="info-value">Melbourne & Victoria Wide</span>
                <p class="text-muted" style="font-size: 0.875rem; margin-top: 4px;">No fixed office — we come to you</p>
              </div>
            </div>

            <div class="info-card">
              <div class="info-icon">🕐</div>
              <div>
                <h4>Operating Hours</h4>
                <span class="info-value">24/7 — All Year Round</span>
                <p class="text-muted" style="font-size: 0.875rem; margin-top: 4px;">Including all public holidays</p>
              </div>
            </div>
          </div>

          <div class="coverage-box glass">
            <h4 style="margin-bottom: 12px;">Areas We Cover</h4>
            <div class="coverage-tags">
              <span class="tag">Melbourne CBD</span>
              <span class="tag">Tullamarine Airport</span>
              <span class="tag">Avalon Airport</span>
              <span class="tag">Yarra Valley</span>
              <span class="tag">Mornington Peninsula</span>
              <span class="tag">Phillip Island</span>
              <span class="tag">Great Ocean Road</span>
              <span class="tag">Geelong</span>
              <span class="tag">Bendigo</span>
              <span class="tag">Ballarat</span>
              <span class="tag">Dandenong Ranges</span>
              <span class="tag">Regional Victoria</span>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-container">
          <h2 style="font-size: 1.75rem; margin-bottom: 0.5rem;">Send Us a Message</h2>
          <p class="text-muted" style="font-size: 0.95rem; margin-bottom: 2rem;">For bookings, we recommend using our <a href="/book" style="color: var(--accent-gold); font-weight: 600;">dedicated booking form</a>. For general enquiries, use the form below.</p>

          <form class="contact-form" action="/api/send-email" method="POST" id="contact-form" data-resend-form>
            <input type="hidden" name="form_type" value="contact">
            <div class="form-group">
              <label for="c-name">Full Name *</label>
              <input type="text" id="c-name" name="name" required class="form-control" placeholder="Your name" />
            </div>
            <div class="form-group">
              <label for="c-email">Email Address *</label>
              <input type="email" id="c-email" name="email" required class="form-control" placeholder="your@email.com" />
            </div>
            <div class="form-group">
              <label for="c-phone">Phone Number</label>
              <input type="tel" id="c-phone" name="phone" class="form-control" placeholder="e.g. 0400 000 000" />
            </div>
            <div class="form-group">
              <label for="c-subject">Subject *</label>
              <select id="c-subject" name="subject" required class="form-control">
                <option value="">Select a topic...</option>
                <option value="booking-enquiry">Booking Enquiry</option>
                <option value="pricing">Pricing & Quotes</option>
                <option value="tour-info">Tour Information</option>
                <option value="corporate">Corporate Accounts</option>
                <option value="accessibility">Accessibility Enquiry</option>
                <option value="feedback">Feedback</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="c-message">Message *</label>
              <textarea id="c-message" name="message" rows="5" required class="form-control" placeholder="Tell us how we can help..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-submit" id="contact-submit-btn">Send Message →</button>
            <p class="form-status" data-form-status aria-live="polite"></p>
          </form>
        </div>

      </div>
    </section>

    <!-- CTA Banner -->
    <section class="cta-banner">
      <div class="container text-center">
        <h2 class="cta-title">Ready to Book <em class="text-gold">Right Now?</em></h2>
        <p class="cta-sub">Skip the form and go straight to our booking page to secure your vehicle.</p>
        <div class="cta-actions">
          <a href="/book" class="btn btn-primary" id="contact-cta-book">Book a Maxi Taxi</a>
          <a href="/tours" class="btn btn-outline-dark" id="contact-cta-tours">View Our Tours</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.page-hero { position: relative; height: 55vh; min-height: 360px; display: flex; align-items: center; overflow: hidden; }
.page-hero-bg { position: absolute; inset: 0; z-index: 0; }
.page-hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
.page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.80) 0%, rgba(0,0,0,0.3) 80%); }
.page-hero-content { position: relative; z-index: 10; color: white; padding-top: 80px; max-width: 700px; }
.page-hero-content .badge { display: inline-block; background: rgba(212,175,55,0.2); border: 1px solid var(--accent-gold); color: var(--accent-gold); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; letter-spacing: 1px; padding: 6px 14px; border-radius: 100px; margin-bottom: 1rem; text-transform: uppercase; }
.page-hero-content h1 { color: white; font-size: clamp(2rem, 4.5vw, 3.2rem); line-height: 1.15; margin-bottom: 1rem; }
.page-hero-content p { color: rgba(255,255,255,0.8); font-size: 1.05rem; }

.section-tag { display: inline-block; color: var(--accent-gold); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
.section-title { font-size: clamp(1.75rem, 3.5vw, 2.6rem); margin-bottom: 1.5rem; }

/* Layout */
.contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }

/* Info Cards */
.info-cards { display: flex; flex-direction: column; gap: 20px; margin-bottom: 28px; }
.info-card { display: flex; align-items: flex-start; gap: 16px; padding: 20px 24px; background: var(--bg-secondary); border-radius: var(--border-radius); border: 1px solid var(--bg-tertiary); transition: var(--transition); }
.info-card:hover { border-color: var(--accent-gold); }
.info-icon { font-size: 1.75rem; flex-shrink: 0; }
.info-card h4 { font-size: 0.875rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 4px; }
.info-value { font-family: var(--font-heading); font-size: 1rem; font-weight: 600; color: var(--text-main); }
a.info-value:hover { color: var(--accent-gold); }

/* Coverage */
.coverage-box { padding: 24px; border-radius: var(--border-radius); background: var(--bg-secondary); border: 1px solid var(--bg-tertiary); }
.coverage-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
.tag { padding: 5px 12px; background: var(--bg-primary); border: 1px solid var(--bg-tertiary); border-radius: 100px; font-size: 0.8rem; font-weight: 500; color: var(--text-muted); }

/* Contact Form */
.contact-form-container { background: var(--bg-primary); border: 1px solid var(--bg-tertiary); border-radius: var(--border-radius); padding: 40px; }
.form-group { margin-bottom: 20px; }
label { display: block; margin-bottom: 8px; font-size: 0.875rem; font-weight: 600; }
.form-control { width: 100%; padding: 12px 16px; border: 1.5px solid var(--bg-tertiary); border-radius: var(--border-radius-sm); font-family: var(--font-body); font-size: 0.95rem; color: var(--text-main); background-color: var(--bg-secondary); transition: var(--transition); }
.form-control:focus { outline: none; border-color: var(--accent-gold); background-color: var(--bg-primary); box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1); }
textarea.form-control { resize: vertical; min-height: 120px; }
.btn-submit { width: 100%; padding: 14px; font-size: 1rem; }
.btn-submit:disabled { opacity: 0.68; cursor: wait; }
.form-status {
  min-height: 22px;
  margin-top: 14px;
  text-align: center;
  font-size: 0.9rem;
  font-weight: 600;
}
.form-status[data-tone="success"] { color: #1b7f43; }
.form-status[data-tone="error"] { color: #b42318; }
.form-status[data-tone="neutral"] { color: var(--text-muted); }

/* CTA */
.cta-banner { background: var(--accent-dark); padding: 80px 0; }
.cta-title { color: white; font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin-bottom: 1rem; }
.cta-sub { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 2.5rem; }
.cta-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; }
.btn-outline-dark { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: var(--font-heading); font-weight: 500; font-size: 1rem; border-radius: var(--border-radius-sm); border: 1.5px solid rgba(255,255,255,0.3); color: white; transition: var(--transition); }
.btn-outline-dark:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.6); }

@media (max-width: 900px) {
  .contact-layout { grid-template-columns: 1fr; }
  .contact-form-container { padding: 28px 20px; }
}
</style>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import business from '../data/business.js';

import van11a     from '../assets/van-exterior-1.webp';
import van11b     from '../assets/van-exterior-2.webp';
import van13a     from '../assets/van-exterior-3.webp';
import van13b     from '../assets/van-exterior-5.webp';
import int2       from '../assets/van-interior-2.webp';
import int3       from '../assets/van-interior-3.webp';
import fleet3     from '../assets/van-fleet-3.webp';
import familyBabyImg from '../assets/family-baby-seat-taxi.webp';
import familyInteriorImg from '../assets/family-maxi-taxi-interior.webp';
import hotelAirportImg from '../assets/hotel-airport-maxi-taxi.webp';
---

<Layout
  title="Maxi Taxi Fleet Melbourne"
  description="Explore 11 and 13-seater maxi taxi options for Melbourne airport transfers, families, groups, luggage, accessibility requests, events, and regional travel."
>
  <Header />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="page-hero-bg">
        <Image src={familyInteriorImg} alt="Premium Maxi Taxi Melbourne family and group seating interior Melbourne" width={1440} height={525} class="page-hero-img" quality={55} />
        <div class="page-hero-overlay"></div>
      </div>
      <div class="container page-hero-content">
        <span class="badge">✦ Vehicle Options</span>
        <h1>Maxi Taxi <em class="text-gold">Vehicle Options</em></h1>
        <p>11 and 13-seater vehicle options for groups, luggage, families, events, schools, airport transfers, accessibility requests, and longer Victorian routes.</p>
        <a href="/book" class="btn btn-primary" id="fleet-hero-book">Book a Vehicle</a>
      </div>
    </section>

    <!-- Vehicle 1: 11-seater -->
    <section class="section" id="eleven-seater">
      <div class="container">
        <div class="section-tag">Vehicle Type 01</div>
        <h2 class="section-title">11-Seater Maxi Taxi Option</h2>
        <p class="section-sub">A practical fit for medium-sized groups, family airport travel, luggage-heavy trips, school movements, and corporate passengers who want to stay together.</p>

        <div class="vehicle-layout">
          <div class="vehicle-images">
            <Image src={familyBabyImg} alt="11-seater maxi taxi interior with family seating and baby seat" width={700} height={460} class="v-main-img" quality={58} />
            <div class="v-thumbs">
              <Image src={van11b} alt="11-seater Maxi Cab side view premium" width={340} height={220} class="v-thumb" quality={60} />
              <Image src={familyInteriorImg} alt="11-seater interior seating and child-seat planning" width={340} height={220} class="v-thumb" quality={58} />
            </div>
          </div>
          <div class="vehicle-specs-panel">
            <h3>Specifications</h3>
            <div class="spec-grid">
              <div class="spec-item"><span class="spec-label">Capacity</span><span class="spec-val">Up to 11 passengers</span></div>
              <div class="spec-item"><span class="spec-label">Luggage</span><span class="spec-val">Large underfloor storage</span></div>
              <div class="spec-item"><span class="spec-label">Climate</span><span class="spec-val">Dual-zone air conditioning</span></div>
              <div class="spec-item"><span class="spec-label">Seating</span><span class="spec-val">Group seating layout</span></div>
              <div class="spec-item"><span class="spec-label">Requests</span><span class="spec-val">Child-seat and luggage notes</span></div>
              <div class="spec-item"><span class="spec-label">Best Use</span><span class="spec-val">Families, airport and events</span></div>
            </div>
            <p class="text-muted" style="font-size: 0.9rem; margin-top: 1rem;">Ideal for: Yarra Valley wine tours, airport transfers, family outings, small corporate events.</p>
            <a href="/book?vehicle=11seater" class="btn btn-primary" style="margin-top:1.5rem;" id="book-11">Book 11-Seater</a>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Vehicle 2: 13-seater -->
    <section class="section" id="thirteen-seater">
      <div class="container">
        <div class="section-tag">Vehicle Type 02</div>
        <h2 class="section-title">13-Seater Maxi Cab</h2>
        <p class="section-sub">A larger option for guest groups, school trips, cruise luggage, regional day trips, event transfers, and bigger family bookings.</p>

        <div class="vehicle-layout reverse">
          <div class="vehicle-specs-panel">
            <h3>Specifications</h3>
            <div class="spec-grid">
              <div class="spec-item"><span class="spec-label">Capacity</span><span class="spec-val">Up to 13 passengers</span></div>
              <div class="spec-item"><span class="spec-label">Wheelchairs</span><span class="spec-val">Hoist-equipped variants available</span></div>
              <div class="spec-item"><span class="spec-label">Luggage</span><span class="spec-val">Extra-large cargo compartment</span></div>
              <div class="spec-item"><span class="spec-label">Trip Types</span><span class="spec-val">Airport, cruise, events</span></div>
              <div class="spec-item"><span class="spec-label">Planning</span><span class="spec-val">Stops and return trips</span></div>
              <div class="spec-item"><span class="spec-label">Requests</span><span class="spec-val">Pre-booking required</span></div>
            </div>
            <p class="text-muted" style="font-size: 0.9rem; margin-top: 1rem;">Ideal for: Weddings, Great Ocean Road tours, school groups, large corporate transfers.</p>
            <a href="/book?vehicle=13seater" class="btn btn-primary" style="margin-top:1.5rem;" id="book-13">Book 13-Seater</a>
          </div>
          <div class="vehicle-images">
            <Image src={van13a} alt="13-seater Maxi Taxi exterior large group Victoria" width={700} height={460} class="v-main-img" quality={62} />
            <div class="v-thumbs">
              <Image src={van13b} alt="13-seater Maxi Cab exterior rear view" width={340} height={220} class="v-thumb" quality={60} />
              <Image src={hotelAirportImg} alt="Maxi taxi luggage space for hotel and airport transfers" width={340} height={220} class="v-thumb" quality={58} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Interior Gallery -->
    <section class="section section-light" id="interior-gallery">
      <div class="container text-center">
        <div class="section-tag">Inside Look</div>
        <h2 class="section-title">Interior and Exterior <em class="text-gold">Reference Photos</em></h2>
        <p class="section-sub">Use these photos to understand the type of space available, then include passenger count, luggage, prams, wheelchair notes, or equipment details in the booking.</p>
        <div class="photo-grid">
          <Image src={familyBabyImg} alt="Baby-seat taxi interior for Melbourne family bookings" width={600} height={380} class="grid-photo" quality={58} />
          <Image src={familyInteriorImg} alt="Maxi taxi interior for families groups and prams" width={600} height={380} class="grid-photo" quality={58} />
          <Image src={hotelAirportImg} alt="Hotel and airport maxi taxi transfer with luggage" width={600} height={380} class="grid-photo" quality={58} />
          <Image src={int2} alt="Maxi Taxi interior rear cabin temperature control" width={600} height={380} class="grid-photo" quality={62} />
          <Image src={fleet3} alt="Premium Maxi Taxi Melbourne side profile Melbourne" width={600} height={380} class="grid-photo" quality={62} />
          <Image src={van13b} alt="Maxi Cab rear exterior vehicle reference" width={600} height={380} class="grid-photo" quality={62} />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-banner">
      <div class="container text-center">
        <h2 class="cta-title">Choose the <em class="text-gold">Right Vehicle</em></h2>
        <p class="cta-sub">Book online or call with the trip type, passenger count, luggage, accessibility notes, pickup, destination, and timing.</p>
        <div class="cta-actions">
          <a href="/book" class="btn btn-primary" id="fleet-cta-book">Book Now</a>
          <a href={business.phoneHref} class="btn btn-outline-dark" id="fleet-cta-call">Call Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.page-hero { position: relative; height: 70vh; min-height: 480px; display: flex; align-items: center; overflow: hidden; }
.page-hero-bg { position: absolute; inset: 0; z-index: 0; }
.page-hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
.page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.25) 80%); }
.page-hero-content { position: relative; z-index: 10; color: white; padding-top: 80px; max-width: 700px; }
.page-hero-content .badge { display: inline-block; background: rgba(212,175,55,0.2); border: 1px solid var(--accent-gold); color: var(--accent-gold); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; letter-spacing: 1px; padding: 6px 14px; border-radius: 100px; margin-bottom: 1rem; text-transform: uppercase; }
.page-hero-content h1 { color: white; font-size: clamp(2rem, 4.5vw, 3.5rem); line-height: 1.15; margin-bottom: 1rem; }
.page-hero-content p { color: rgba(255,255,255,0.8); font-size: 1.1rem; margin-bottom: 2rem; }

.section-tag { display: inline-block; color: var(--accent-gold); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
.section-title { font-size: clamp(1.75rem, 3.5vw, 2.6rem); margin-bottom: 1rem; }
.section-sub { font-size: 1.05rem; color: var(--text-muted); max-width: 620px; margin: 0 auto 3rem; text-align: center; }
.section-divider { border: none; border-top: 1px solid var(--bg-tertiary); margin: 20px 0 60px; }

.vehicle-layout { display: grid; grid-template-columns: 1.3fr 1fr; gap: 60px; align-items: start; }
.vehicle-layout.reverse { grid-template-columns: 1fr 1.3fr; }
.v-main-img { width: 100%; height: 340px; object-fit: cover; border-radius: var(--border-radius); box-shadow: var(--shadow-md); display: block; margin-bottom: 16px; }
.v-thumbs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.v-thumb { width: 100%; height: 160px; object-fit: cover; border-radius: var(--border-radius-sm); display: block; }
.vehicle-specs-panel { padding: 40px; background: var(--bg-secondary); border-radius: var(--border-radius); border: 1px solid var(--bg-tertiary); }
.vehicle-specs-panel h3 { font-size: 1.4rem; margin-bottom: 24px; }
.spec-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
.spec-item { display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; padding-bottom: 14px; border-bottom: 1px solid var(--bg-tertiary); }
.spec-item:last-child { border-bottom: none; }
.spec-label { font-weight: 600; font-size: 0.875rem; color: var(--text-muted); white-space: nowrap; }
.spec-val { font-size: 0.875rem; font-weight: 500; text-align: right; }

.photo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 40px; }
.grid-photo { width: 100%; height: 240px; object-fit: cover; border-radius: var(--border-radius); display: block; transition: transform 0.5s ease; }
.grid-photo:hover { transform: scale(1.03); }

.cta-banner { background: var(--accent-dark); padding: 80px 0; }
.cta-title { color: white; font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin-bottom: 1rem; }
.cta-sub { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 2.5rem; }
.cta-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; }
.btn-outline-dark { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: var(--font-heading); font-weight: 500; font-size: 1rem; border-radius: var(--border-radius-sm); border: 1.5px solid rgba(255,255,255,0.3); color: white; transition: var(--transition); }
.btn-outline-dark:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.6); }

@media (max-width: 900px) {
  .vehicle-layout, .vehicle-layout.reverse { grid-template-columns: 1fr; }
  .photo-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .photo-grid { grid-template-columns: 1fr; }
  .v-thumbs { grid-template-columns: 1fr; }
}
</style>

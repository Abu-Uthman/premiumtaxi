---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import servicesData from '../data/services.json';
import locations from '../data/locations.js';
import priorityPages from '../data/priorityPages.json';

const staticPages = [
  { title: 'Home', href: '/' },
  { title: 'About Us', href: '/about/' },
  { title: 'Book Online', href: '/book/' },
  { title: 'Contact', href: '/contact/' },
  { title: 'FAQ', href: '/faq/' },
  { title: 'Fleet', href: '/fleet/' },
  { title: 'Service Areas', href: '/locations/' },
  { title: 'Taxi Services', href: '/services/' },
  { title: 'Day Tours', href: '/tours/' }
];

const servicePages = servicesData
  .map((item) => ({
    title: item.name,
    href: `/services/${item.slug}/`,
    description: item.description
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const locationPages = locations
  .map((item) => ({
    title: `${item.name} Taxi Service Area`,
    href: `/locations/${item.slug}/`,
    description: item.shortDescription
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const landingPages = priorityPages
  .map((item) => ({
    title: item.h1 || item.title,
    href: `/taxi-services/${item.slug}/`,
    description: item.description
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const totalPages = staticPages.length + servicePages.length + locationPages.length + landingPages.length;

const groups = [
  {
    label: 'Core Pages',
    count: staticPages.length,
    pages: staticPages
  },
  {
    label: 'Service Pages',
    count: servicePages.length,
    pages: servicePages
  },
  {
    label: 'Location Pages',
    count: locationPages.length,
    pages: locationPages
  },
  {
    label: 'Targeted Taxi Landing Pages',
    count: landingPages.length,
    pages: landingPages
  }
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Premium Maxi Cab website pages',
  numberOfItems: totalPages,
  itemListElement: groups.flatMap((group) =>
    group.pages.map((page, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: page.title,
      url: new URL(page.href, Astro.site || 'https://www.premiummaxicab.com.au').href
    }))
  )
};
---

<Layout
  title="Website Sitemap"
  description="Browse all Premium Maxi Cab website pages, including Melbourne taxi services, suburb service areas, and targeted taxi landing pages."
>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <main>
    <section class="sitemap-hero">
      <div class="container sitemap-hero-inner">
        <p class="section-tag">Website Sitemap</p>
        <h1>All Published Website Pages</h1>
        <p>
          This page lists the live pages created for Premium Maxi Cab, including service hubs,
          Melbourne suburb pages, and targeted taxi landing pages.
        </p>
        <div class="sitemap-stats" aria-label="Published page counts">
          {groups.map((group) => (
            <div class="stat-box">
              <strong>{group.count}</strong>
              <span>{group.label}</span>
            </div>
          ))}
          <div class="stat-box total">
            <strong>{totalPages}</strong>
            <span>Total indexed URLs in HTML sitemap</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container sitemap-layout">
        {groups.map((group) => (
          <section class="sitemap-group" aria-labelledby={`group-${group.label.toLowerCase().replaceAll(' ', '-')}`}>
            <div class="group-heading">
              <h2 id={`group-${group.label.toLowerCase().replaceAll(' ', '-')}`}>{group.label}</h2>
              <span>{group.count} pages</span>
            </div>
            <div class="page-list">
              {group.pages.map((page) => (
                <a class="page-row" href={page.href}>
                  <span>{page.title}</span>
                  {page.description && <small>{page.description}</small>}
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .sitemap-hero {
    padding: 150px 0 70px;
    background: linear-gradient(135deg, #121212 0%, #242424 58%, #3a3217 100%);
    color: #fff;
  }

  .sitemap-hero h1,
  .sitemap-hero p {
    color: #fff;
  }

  .sitemap-hero h1 {
    max-width: 760px;
    font-size: clamp(2.4rem, 5vw, 4.5rem);
  }

  .sitemap-hero-inner > p:not(.section-tag) {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.78);
  }

  .sitemap-stats {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
    margin-top: 34px;
  }

  .stat-box {
    min-height: 112px;
    padding: 20px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
  }

  .stat-box strong {
    display: block;
    color: var(--accent-gold);
    font-family: var(--font-heading);
    font-size: 2.2rem;
    line-height: 1;
    margin-bottom: 10px;
  }

  .stat-box span {
    display: block;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
  }

  .stat-box.total {
    background: rgba(212, 175, 55, 0.14);
    border-color: rgba(212, 175, 55, 0.35);
  }

  .sitemap-layout {
    display: grid;
    gap: 42px;
  }

  .sitemap-group {
    padding-bottom: 42px;
    border-bottom: 1px solid var(--bg-tertiary);
  }

  .sitemap-group:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .group-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 18px;
  }

  .group-heading h2 {
    margin-bottom: 0;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .group-heading span {
    color: var(--text-muted);
    white-space: nowrap;
  }

  .page-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .page-row {
    display: grid;
    gap: 6px;
    min-height: 92px;
    padding: 16px;
    border: 1px solid var(--bg-tertiary);
    border-radius: 8px;
    background: #fff;
    box-shadow: var(--shadow-sm);
  }

  .page-row:hover {
    border-color: rgba(212, 175, 55, 0.55);
    transform: translateY(-2px);
  }

  .page-row span {
    color: var(--text-main);
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.25;
  }

  .page-row small {
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .sitemap-stats,
    .page-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .sitemap-hero {
      padding: 120px 0 52px;
    }

    .sitemap-stats,
    .page-list {
      grid-template-columns: 1fr;
    }

    .group-heading {
      align-items: start;
      flex-direction: column;
      gap: 4px;
    }
  }
</style>

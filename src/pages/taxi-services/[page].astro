---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import heroImg from '../../assets/van-exterior-1.webp';
import familyBabyImg from '../../assets/family-baby-seat-taxi.webp';
import familyInteriorImg from '../../assets/family-maxi-taxi-interior.webp';
import hotelAirportImg from '../../assets/hotel-airport-maxi-taxi.webp';
import servicesData from '../../data/services.json';
import locationsData from '../../data/locations.js';
import priorityPagesData from '../../data/priorityPages.json';
import business, { getBusinessProviderSchema } from '../../data/business.js';

export async function getStaticPaths() {
  return priorityPagesData.map((page) => ({
    params: { page: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const service = servicesData.find((item) => item.slug === page.primaryServiceSlug) || servicesData[0];
const pageLocations = page.locationSlugs
  .map((slug) => locationsData.find((loc) => loc.slug === slug))
  .filter(Boolean);
const primaryLocation = pageLocations[0];
const relatedServices = servicesData.filter((item) => item.slug !== service.slug).slice(0, 5);
const relatedLocations = primaryLocation
  ? locationsData.filter((loc) => loc.region === primaryLocation.region && loc.slug !== primaryLocation.slug).slice(0, 6)
  : locationsData.slice(0, 6);
const playbooks = {
  "taxi-melbourne": {
    label: "Flexible Melbourne taxi booking",
    promise: "matched to the actual trip, whether the passenger needs a standard taxi, maxi taxi, SUV or wagon, baby-seat request, wheelchair-accessible transport, parcel movement, or airport transfer.",
    vehicleFit: ["standard taxi for point-to-point trips", "maxi taxi for groups and luggage", "SUV, wagon, baby-seat, wheelchair, or parcel taxi by request"],
    bookingFields: ["pickup time", "destination", "passenger count", "vehicle or access request"],
    popularTrips: ["CBD to airport transfer", "suburb to appointment", "family taxi with luggage", "late-night return trip"]
  },
  "airport-taxi-melbourne": {
    label: "Airport taxi planning",
    promise: "planned around flight time, terminal, luggage, passenger count, child-seat or accessibility requirements, and the best pickup route instead of treating airport travel as a basic local trip.",
    vehicleFit: ["standard airport taxi", "maxi taxi for luggage-heavy airport trips", "SUV, wagon, baby-seat, or wheelchair request"],
    bookingFields: ["flight time", "terminal", "luggage count", "passenger and child-seat details"],
    popularTrips: ["home to Melbourne Airport", "Melbourne Airport to hotel", "Avalon Airport transfer", "airport trip with extra luggage"]
  },
  "maxi-cab-melbourne": {
    label: "Group and luggage taxi",
    promise: "built for groups that need one vehicle, clear pickup timing, and enough space for passengers, bags, prams, sports gear, or shopping.",
    vehicleFit: ["11 and 13-seat maxi taxi options", "Luggage-friendly layouts", "Suitable for families, events, schools, and airports"],
    bookingFields: ["passenger count", "luggage or prams", "pickup access", "extra stops"],
    popularTrips: ["home to Melbourne Airport", "family event transfer", "school or sports group pickup", "outer-suburb return trip"]
  },
  "wheelchair-accessible-taxi-melbourne": {
    label: "Accessible taxi planning",
    promise: "planned around boarding time, mobility equipment, carers, pickup access, and appointment deadlines instead of treating accessibility as an afterthought.",
    vehicleFit: ["wheelchair-accessible vehicle request", "space for carers and mobility equipment", "appointment and hospital timing support"],
    bookingFields: ["wheelchair type", "carer count", "pickup access", "appointment time"],
    popularTrips: ["hospital appointment", "family outing", "airport transfer with mobility equipment", "community or NDIS-style transport"]
  },
  "baby-seat-taxi-melbourne": {
    label: "Family taxi planning",
    promise: "focused on families who need child-seat requests, pram space, luggage room, and a vehicle that is planned before pickup.",
    vehicleFit: ["baby-seat and booster requests", "space for prams and suitcases", "family-sized maxi taxi options"],
    bookingFields: ["child age", "seat or booster request", "pram count", "luggage count"],
    popularTrips: ["family airport transfer", "school or childcare pickup", "medical appointment", "holiday luggage transfer"]
  },
  "parcel-delivery-taxi-melbourne": {
    label: "Direct parcel taxi",
    promise: "for urgent point-to-point items where a direct taxi delivery is more practical than waiting for a standard courier run.",
    vehicleFit: ["small parcels and documents", "direct pickup-to-delivery movement", "clear sender and receiver details"],
    bookingFields: ["item size", "pickup contact", "delivery contact", "handling notes"],
    popularTrips: ["CBD document delivery", "forgotten luggage transfer", "business item movement", "industrial-area delivery"]
  },
  "corporate-transfers-melbourne": {
    label: "Business transport",
    promise: "set up for offices, hotels, conferences, client pickups, staff movements, and airport travel where timing and presentation matter.",
    vehicleFit: ["SUV, wagon, silver service, or maxi taxi requests", "team and luggage planning", "meeting and flight timing notes"],
    bookingFields: ["company or guest name", "meeting time", "flight details", "luggage count"],
    popularTrips: ["hotel to office", "conference transfer", "airport client pickup", "staff group movement"]
  },
  "group-transfers-melbourne": {
    label: "Multi-passenger transfer",
    promise: "keeps groups together across events, wineries, sports, hotels, airports, and multi-stop itineraries.",
    vehicleFit: ["larger passenger capacity", "space for event gear or luggage", "multi-stop pickup planning"],
    bookingFields: ["guest count", "venue names", "return time", "stop sequence"],
    popularTrips: ["wedding guest transfer", "winery day trip", "sports team movement", "night-out return trip"]
  },
  "wedding-event-transfers-melbourne": {
    label: "Event movement",
    promise: "designed around venue timing, formal clothing, guest groups, late returns, and clear meeting points.",
    vehicleFit: ["guest group transfers", "late-night return bookings", "hotel, venue, and home pickups"],
    bookingFields: ["venue address", "guest count", "return time", "pickup meeting point"],
    popularTrips: ["ceremony to reception", "hotel to venue", "late-night guest return", "race day or concert transfer"]
  },
  "cruise-transfer-melbourne": {
    label: "Cruise luggage transfer",
    promise: "matches cruise passengers with luggage-friendly vehicles and fixed boarding-time planning for Station Pier and hotel connections.",
    vehicleFit: ["large suitcase capacity", "hotel and airport connections", "Station Pier timing"],
    bookingFields: ["ship or terminal", "boarding time", "suitcase count", "hotel or flight details"],
    popularTrips: ["hotel to Station Pier", "airport to cruise terminal", "home to port", "port to hotel"]
  },
  "school-runs-student-transport-melbourne": {
    label: "Student transport",
    promise: "planned around school times, authorised contacts, student groups, bags, sports gear, and predictable pickup instructions.",
    vehicleFit: ["student group capacity", "space for bags or sports gear", "recurring or one-off booking notes"],
    bookingFields: ["school name", "authorised contact", "student count", "equipment notes"],
    popularTrips: ["school pickup", "sports fixture", "excursion movement", "camp luggage transfer"]
  },
  "outer-melbourne-taxi": {
    label: "Longer-distance taxi",
    promise: "built for outer Melbourne and regional trips where route, luggage, passengers, and return timing need to be arranged before departure.",
    vehicleFit: ["long-distance taxi and maxi cab options", "airport and regional route planning", "return-trip coordination"],
    bookingFields: ["route", "pickup time", "return details", "passenger and luggage count"],
    popularTrips: ["regional airport transfer", "outer-suburb event trip", "Melbourne to regional city", "day trip return"]
  },
  "suv-wagon-taxi-melbourne": {
    label: "Extra luggage taxi",
    promise: "for passengers who need more luggage space and comfort than a standard sedan without necessarily needing a full maxi cab.",
    vehicleFit: ["SUV or wagon requests", "extra boot space", "small groups and business passengers"],
    bookingFields: ["passenger count", "luggage size", "comfort preference", "flight or meeting time"],
    popularTrips: ["airport with extra bags", "business transfer", "family shopping trip", "hotel pickup"]
  },
  "silver-service-taxi-melbourne": {
    label: "Premium point-to-point taxi",
    promise: "for passengers who want a cleaner, more polished point-to-point ride for business, appointments, hotels, and airport trips.",
    vehicleFit: ["premium taxi or SUV request", "business and hotel pickups", "appointment and airport timing"],
    bookingFields: ["pickup presentation notes", "meeting or flight time", "luggage count", "preferred vehicle type"],
    popularTrips: ["CBD hotel pickup", "airport transfer", "business appointment", "premium event arrival"]
  }
};
const playbook = playbooks[service.slug] || playbooks["maxi-cab-melbourne"];
const locationName = primaryLocation?.name || "Melbourne";
const nearbySuburbNames = primaryLocation?.nearbySuburbs || relatedLocations.map((loc) => loc.name).slice(0, 3);
const priorityHeroImages = {
  "taxi-melbourne": hotelAirportImg,
  "airport-taxi-melbourne": hotelAirportImg,
  "baby-seat-taxi-melbourne": familyBabyImg,
  "corporate-transfers-melbourne": hotelAirportImg,
  "cruise-transfer-melbourne": hotelAirportImg,
  "suv-wagon-taxi-melbourne": hotelAirportImg,
  "silver-service-taxi-melbourne": hotelAirportImg,
  "outer-melbourne-taxi": hotelAirportImg,
  "maxi-cab-melbourne": familyInteriorImg,
  "group-transfers-melbourne": familyInteriorImg,
  "school-runs-student-transport-melbourne": familyBabyImg
};
const priorityHeroImage = priorityHeroImages[service.slug] || heroImg;
const priorityPanelImage = service.slug === "baby-seat-taxi-melbourne" ? familyBabyImg : familyInteriorImg;

const canonical = new URL(Astro.url.pathname, Astro.site || 'https://www.premiummaxicab.com.au').href;
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL('/', Astro.site || 'https://www.premiummaxicab.com.au').href },
    { "@type": "ListItem", "position": 2, "name": "Taxi Services", "item": new URL('/taxi-services/', Astro.site || 'https://www.premiummaxicab.com.au').href },
    { "@type": "ListItem", "position": 3, "name": page.h1, "item": canonical }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": page.h1,
  "description": page.description,
  "serviceType": service.name,
  "provider": getBusinessProviderSchema(),
  "areaServed": pageLocations.map((loc) => ({
    "@type": "City",
    "name": loc.name
  })),
  "url": canonical
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": page.faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<Layout title={`${page.h1} | Taxi Booking`} description={page.description}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main>
    <section class="priority-hero">
      <div class="priority-hero-bg">
        <Image src={priorityHeroImage} alt={`${page.h1} taxi service Melbourne Victoria`} width={1440} height={570} class="hero-img" loading="eager" quality={55} />
        <div class="hero-overlay"></div>
      </div>
      <div class="container hero-content">
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/services">Services</a>
          <span>/</span>
          <span>{page.h1}</span>
        </nav>
        <span class="badge">Pre-booked Melbourne taxi service</span>
        <h1>{page.h1}</h1>
        <p>{page.description}</p>
        <div class="hero-actions">
          <a href="/book" class="btn btn-primary">Book Now</a>
          <a href={business.phoneHref} class="btn btn-ghost">Call</a>
          <a href="/contact" class="btn btn-ghost">Get Quote</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container landing-grid">
        <article>
          <div class="section-tag">{playbook.label}</div>
          <h2>{page.h1} for the Trip People Actually Need</h2>
          <p>{page.localNotes}</p>
          <p>
            This page is not a generic suburb page. It is for {page.h1.toLowerCase()} bookings {playbook.promise} The booking should capture the practical details before dispatch, so the vehicle type, timing, route, and passenger requirements are clear.
          </p>

          <h3>Best For</h3>
          <div class="use-case-grid">
            {page.useCases.map((item) => (
              <div class="use-card">
                <span>✓</span>
                <strong>{item}</strong>
              </div>
            ))}
          </div>

          <h3>Best Taxi Options for This Request</h3>
          <div class="option-grid">
            {playbook.vehicleFit.map((item) => (
              <div class="option-card">
                <strong>{item}</strong>
                <p>Useful for {locationName} trips where timing, vehicle space, and pickup instructions need to be settled before the driver arrives.</p>
              </div>
            ))}
          </div>

          <h3>Popular Trips From {locationName}</h3>
          <div class="trip-list">
            {playbook.popularTrips.map((trip) => (
              <div>
                <span>{trip}</span>
                <p>{page.h1} bookings can be planned around {trip}, nearby suburbs such as {nearbySuburbNames.slice(0, 2).join(" and ")}, and the final destination.</p>
              </div>
            ))}
          </div>

          <h3>Linked Service and Areas</h3>
          <div class="link-row">
            <a href={`/services/${service.slug}`}>{service.name}</a>
            {pageLocations.map((loc) => (
              <a href={`/locations/${loc.slug}`}>{loc.name}</a>
            ))}
          </div>
        </article>

        <aside class="booking-panel">
          <Image src={priorityPanelImage} alt="Clean maxi taxi interior with spacious passenger seating" width={520} height={340} class="panel-img" quality={58} />
          <div class="panel-body">
            <h2>Plan the Ride Properly</h2>
            <p>For this page, the most important booking details are: {playbook.bookingFields.join(", ")}. Add pickup, destination, preferred time, and any notes that affect loading or timing.</p>
            <a href="/book" class="btn btn-primary">Start Booking</a>
            <a href={business.phoneHref} class="panel-call">Call {business.phoneDisplay}</a>
          </div>
        </aside>
      </div>
    </section>

    <section class="section section-light">
      <div class="container">
        <div class="section-tag text-center">Why Pre-Book</div>
        <h2 class="section-title text-center">A Better Fit Than a Random Taxi</h2>
        <div class="trust-grid">
          <div class="trust-card"><strong>Vehicle Fit</strong><p>{page.h1} should be matched to passengers, luggage, child seats, wheelchair access, parcel size, or group size before pickup.</p></div>
          <div class="trust-card"><strong>Timing Fit</strong><p>Early flights, schools, medical appointments, events, cruise boarding, and regional routes all need different timing buffers.</p></div>
          <div class="trust-card"><strong>Local Fit</strong><p>{locationName} trips often connect nearby suburbs, airports, hospitals, hotels, venues, stations, and outer-Melbourne routes.</p></div>
          <div class="trust-card"><strong>Booking Fit</strong><p>The form and phone CTA collect the details that decide whether a standard taxi, SUV, wagon, maxi cab, or specialist request is suitable.</p></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container related-grid">
        <div>
          <div class="section-tag">Related Services</div>
          <h2>Other Taxi Options</h2>
          <div class="stack-links">
            {relatedServices.map((item) => (
              <a href={`/services/${item.slug}`}>{item.name}</a>
            ))}
          </div>
        </div>
        <div>
          <div class="section-tag">Nearby Coverage</div>
          <h2>Nearby Service Areas</h2>
          <div class="stack-links">
            {relatedLocations.map((loc) => (
              <a href={`/locations/${loc.slug}`}>{loc.name}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section section-light">
      <div class="container faq-wrap">
        <div class="section-tag">Common Questions</div>
        <h2>Questions About {page.h1}</h2>
        {page.faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.priority-hero {
  position: relative;
  min-height: 620px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.priority-hero-bg {
  position: absolute;
  inset: 0;
}
.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, rgba(0,0,0,0.86), rgba(0,0,0,0.5), rgba(0,0,0,0.18));
}
.hero-content {
  position: relative;
  z-index: 1;
  color: white;
  max-width: 830px;
  padding-top: 90px;
}
.breadcrumb {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
  color: rgba(255,255,255,0.72);
  font-size: 0.88rem;
}
.breadcrumb a:hover { color: var(--accent-gold); }
.badge {
  display: inline-block;
  color: var(--accent-gold);
  border: 1px solid rgba(212,175,55,0.65);
  background: rgba(212,175,55,0.16);
  border-radius: 999px;
  padding: 6px 14px;
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.hero-content h1 {
  color: white;
  font-size: clamp(2.4rem, 5vw, 4.4rem);
  line-height: 1.08;
}
.hero-content p {
  color: rgba(255,255,255,0.86);
  font-size: 1.1rem;
  max-width: 720px;
}
.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px;
}
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border: 1px solid rgba(255,255,255,0.45);
  border-radius: var(--border-radius-sm);
  color: #fff;
  font-family: var(--font-heading);
  font-weight: 600;
}
.landing-grid,
.related-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 380px;
  gap: 52px;
  align-items: start;
}
.related-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}
article h2,
.related-grid h2 {
  font-size: clamp(1.8rem, 3vw, 2.7rem);
}
article p,
.booking-panel p,
.trust-card p {
  color: var(--text-muted);
  line-height: 1.75;
}
article h3 {
  margin: 32px 0 16px;
}
.use-case-grid,
.option-grid,
.trust-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}
.trust-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}
.use-card,
.option-card,
.trust-card {
  padding: 18px;
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius-sm);
  background: #fff;
  box-shadow: var(--shadow-sm);
}
.option-card p {
  margin: 8px 0 0;
  color: var(--text-muted);
  font-size: 0.92rem;
  line-height: 1.6;
}
.trip-list {
  display: grid;
  gap: 12px;
}
.trip-list div {
  padding: 16px 18px;
  border-left: 3px solid var(--accent-gold);
  background: var(--bg-secondary);
}
.trip-list span {
  display: block;
  font-family: var(--font-heading);
  font-weight: 700;
  margin-bottom: 4px;
}
.trip-list p {
  margin: 0;
  color: var(--text-muted);
  line-height: 1.6;
}
.use-card {
  display: flex;
  gap: 10px;
  align-items: center;
}
.use-card span { color: var(--accent-gold); font-weight: 800; }
.link-row,
.stack-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.stack-links {
  flex-direction: column;
  align-items: stretch;
}
.link-row a,
.stack-links a {
  display: inline-flex;
  padding: 10px 14px;
  border: 1px solid var(--bg-tertiary);
  border-radius: 999px;
  color: var(--text-main);
  background: #fff;
}
.stack-links a {
  border-radius: var(--border-radius-sm);
}
.link-row a:hover,
.stack-links a:hover {
  border-color: var(--accent-gold);
  color: var(--accent-gold);
}
.booking-panel {
  position: sticky;
  top: 100px;
  overflow: hidden;
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius);
  background: var(--bg-primary);
  box-shadow: var(--shadow-md);
}
.panel-img {
  width: 100%;
  height: 240px;
  object-fit: cover;
}
.panel-body {
  padding: 24px;
}
.panel-call {
  display: inline-flex;
  margin-top: 14px;
  color: var(--accent-gold);
  font-family: var(--font-heading);
  font-weight: 600;
}
.section-title {
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  margin-bottom: 28px;
}
.section-tag {
  display: inline-block;
  color: var(--accent-gold);
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.faq-wrap {
  max-width: 860px;
}
.faq-item {
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius-sm);
  background: var(--bg-primary);
  margin-bottom: 12px;
  overflow: hidden;
}
.faq-item summary {
  padding: 18px 22px;
  cursor: pointer;
  font-family: var(--font-heading);
  font-weight: 600;
}
.faq-item p {
  padding: 0 22px 20px;
  color: var(--text-muted);
}
@media (max-width: 900px) {
  .priority-hero { min-height: 560px; }
  .landing-grid,
  .related-grid,
  .use-case-grid,
  .option-grid,
  .trust-grid { grid-template-columns: 1fr; }
  .booking-panel { position: static; }
}
</style>

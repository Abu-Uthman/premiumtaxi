---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import interior2    from '../assets/van-interior-2.webp';
import groupImg     from '../assets/van-group-1.webp';
import familyBabyImg from '../assets/family-baby-seat-taxi.webp';
import familyInteriorImg from '../assets/family-maxi-taxi-interior.webp';
import hotelAirportImg from '../assets/hotel-airport-maxi-taxi.webp';
import servicesData from '../data/services.json';
import business, { getBusinessProviderSchema } from '../data/business.js';

const provider = getBusinessProviderSchema();

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Premium Maxi Taxi Melbourne Services",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Service",
        "name": "Melbourne Airport Maxi Taxi Transfers",
        "areaServed": "Melbourne and Victoria",
        "provider": provider
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Service",
        "name": "Corporate Group Transport Melbourne",
        "areaServed": "Melbourne and Victoria",
        "provider": provider
      }
    },
    {
      "@type": "ListItem",
      "position": 3,
      "item": {
        "@type": "Service",
        "name": "Wheelchair Accessible Taxi Melbourne",
        "areaServed": "Melbourne and Victoria",
        "provider": provider
      }
    },
    {
      "@type": "ListItem",
      "position": 4,
      "item": {
        "@type": "Service",
        "name": "Large Group Transport Victoria",
        "areaServed": "Melbourne and Victoria",
        "provider": provider
      }
    }
  ]
};
---

<Layout 
  title="Melbourne Taxi Services"
  description="Taxi and maxi cab services for Melbourne airport transfers, wheelchair requests, baby-seat taxis, parcels, events, schools, groups, and outer suburbs."
>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="page-hero-bg">
        <Image src={hotelAirportImg} alt="Premium Maxi Taxi Melbourne hotel airport luggage transfer" width={1440} height={525} class="page-hero-img" quality={55} />
        <div class="page-hero-overlay"></div>
      </div>
      <div class="container page-hero-content">
        <span class="badge">✦ Taxi Service Hub</span>
        <h1>Taxi <em class="text-gold">Services</em><br/>By Trip Type</h1>
        <p>Choose the service that fits the actual request: airport, wheelchair, baby seat, parcel, corporate, school, event, cruise, group, SUV, wagon, maxi cab, or regional travel.</p>
        <a href="/book" class="btn btn-primary" id="services-hero-book">Get a Quote</a>
      </div>
    </section>

    <!-- Service SEO Hub -->
    <section class="section section-light">
      <div class="container">
        <div class="section-tag text-center">All Taxi Services</div>
        <h2 class="section-title text-center">Book the Right Taxi for the Job</h2>
        <p class="section-sub">
          We are not limited to airport transfers. Choose the service that matches your trip, vehicle size, passenger needs, luggage, accessibility, or suburb.
        </p>
        <div class="service-hub-grid">
          {servicesData.map((item) => (
            <a href={`/services/${item.slug}`} class="service-hub-card">
              <h3>{item.name}</h3>
              <p>{item.description}</p>
              <span>View service →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Services List -->
    <section class="section">
      <div class="container">

        <!-- Service 1: Airport -->
        <article class="tour-full-card" id="airport-transfers">
          <div class="tfc-image">
            <Image src={hotelAirportImg} alt="Melbourne airport maxi taxi group luggage transfer Tullamarine Avalon" width={700} height={460} class="tfc-img" quality={58} />
          </div>
          <div class="tfc-content">
            <span class="section-tag">Most Popular</span>
            <h2>Melbourne Airport Transfers</h2>
            <p>Airport transfer bookings should include flight number, terminal, pickup address, passenger count, suitcase count, child-seat requests, accessibility notes, and pickup timing for <strong>Tullamarine</strong> or <strong>Avalon Airport</strong>.</p>
            <ul class="feature-list">
              <li><span class="check">✓</span> Flight number and terminal details</li>
              <li><span class="check">✓</span> Luggage, pram and child-seat notes</li>
              <li><span class="check">✓</span> Pickup access and timing instructions</li>
              <li><span class="check">✓</span> Maxi cab, SUV or wagon request pathway</li>
            </ul>
            <a href="/book?service=airport" class="btn btn-primary" id="book-airport">Book Airport Transfer</a>
          </div>
        </article>

        <hr class="section-divider" />

        <!-- Service 2: Corporate -->
        <article class="tour-full-card reverse" id="corporate-transport">
          <div class="tfc-content">
            <span class="section-tag">Corporate &amp; Events</span>
            <h2>Corporate Group Transport</h2>
            <p>Corporate bookings need practical details: office or hotel pickup, meeting time, client names, luggage, airport connection, passenger count, and whether an SUV, wagon, silver service, or maxi cab is the better fit.</p>
            <ul class="feature-list">
              <li><span class="check">✓</span> Office, hotel, airport and conference transfers</li>
              <li><span class="check">✓</span> Team and client passenger counts</li>
              <li><span class="check">✓</span> Luggage and meeting-time notes</li>
              <li><span class="check">✓</span> Quote requests for recurring travel</li>
            </ul>
            <a href="/book?service=corporate" class="btn btn-primary" id="book-corp">Book Corporate</a>
          </div>
          <div class="tfc-image">
            <Image src={hotelAirportImg} alt="Corporate maxi taxi hotel and airport transfer Melbourne" width={700} height={460} class="tfc-img" quality={58} />
          </div>
        </article>

        <hr class="section-divider" />

        <!-- Service 3: Wheelchair -->
        <article class="tour-full-card" id="wheelchair-accessible">
          <div class="tfc-image">
            <Image src={groupImg} alt="Wheelchair accessible Maxi Taxi Melbourne safe dignified transport" width={700} height={460} class="tfc-img" quality={62} />
          </div>
          <div class="tfc-content">
            <span class="section-tag">Accessibility First</span>
            <h2>Wheelchair Accessible Taxis</h2>
            <p>Accessible taxi bookings should capture wheelchair type, mobility equipment, carers, pickup access, destination, appointment time, return requirements, and luggage before the trip is confirmed.</p>
            <ul class="feature-list">
              <li><span class="check">✓</span> Wheelchair and mobility equipment notes</li>
              <li><span class="check">✓</span> Carer and passenger count</li>
              <li><span class="check">✓</span> Hospital, appointment and home pickup timing</li>
              <li><span class="check">✓</span> Airport, family and community travel requests</li>
            </ul>
            <a href="/book?service=wheelchair" class="btn btn-primary" id="book-wc">Book Accessible Taxi</a>
          </div>
        </article>

        <hr class="section-divider" />

        <!-- Service 4: General Group -->
        <article class="tour-full-card reverse" id="large-group-transport">
          <div class="tfc-content">
            <span class="section-tag">Group Hire</span>
            <h2>Large Group Transport Victoria</h2>
            <p>Heading out as a large group? Weddings, formals, sporting events, concerts, or family reunions — our Maxi Cabs are the perfect way to keep the entire group together without the chaos of multiple vehicles.</p>
            <ul class="feature-list">
              <li><span class="check">✓</span> Up to 13 passengers in one vehicle</li>
              <li><span class="check">✓</span> Ideal for weddings, schools &amp; sports events</li>
              <li><span class="check">✓</span> Point-to-point or hourly rates available</li>
              <li><span class="check">✓</span> Interstate and regional Victoria trips welcome</li>
            </ul>
            <a href="/book?service=group" class="btn btn-primary" id="book-group">Book Group Hire</a>
          </div>
          <div class="tfc-image">
            <Image src={familyInteriorImg} alt="Spacious maxi taxi interior for family and group transport" width={700} height={460} class="tfc-img" quality={58} />
          </div>
        </article>

      </div>
    </section>

    <!-- Interior Gallery -->
    <section class="section section-light">
      <div class="container text-center">
        <div class="section-tag">The Interior Experience</div>
        <h2 class="section-title">Spacious, Clean &amp; <em class="text-gold">Comfortable</em></h2>
        <div class="interior-gallery">
          <Image src={familyBabyImg} alt="Baby seat taxi interior for Melbourne family transfers" width={600} height={400} class="int-photo" quality={58} />
          <Image src={familyInteriorImg} alt="Family maxi taxi interior with child seat and passenger space" width={600} height={400} class="int-photo" quality={58} />
          <Image src={interior2} alt="Maxi Taxi interior headroom and legroom comfort" width={600} height={400} class="int-photo" quality={62} />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-banner">
      <div class="container text-center">
        <h2 class="cta-title">Need Something Specific?</h2>
        <p class="cta-sub">We customise every booking. Tell us your requirements and we'll handle everything else.</p>
        <div class="cta-actions">
          <a href="/book" class="btn btn-primary" id="services-cta-book">Book Now</a>
          <a href={business.phoneHref} class="btn btn-outline-dark" id="services-cta-call">Call {business.phoneDisplay}</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
.page-hero { position: relative; height: 70vh; min-height: 480px; display: flex; align-items: center; overflow: hidden; }
.page-hero-bg { position: absolute; inset: 0; z-index: 0; }
.page-hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
.page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.25) 80%); }
.page-hero-content { position: relative; z-index: 10; color: white; padding-top: 80px; max-width: 700px; }
.page-hero-content .badge {
  display: inline-block; background: rgba(212,175,55,0.2); border: 1px solid var(--accent-gold);
  color: var(--accent-gold); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600;
  letter-spacing: 1px; padding: 6px 14px; border-radius: 100px; margin-bottom: 1rem; text-transform: uppercase;
}
.page-hero-content h1 { color: white; font-size: clamp(2rem, 4.5vw, 3.5rem); line-height: 1.15; margin-bottom: 1rem; }
.page-hero-content p { color: rgba(255,255,255,0.8); font-size: 1.1rem; margin-bottom: 2rem; }

.tour-full-card { display: grid; grid-template-columns: 1.1fr 1fr; gap: 60px; align-items: center; margin-bottom: 60px; }
.tour-full-card.reverse { grid-template-columns: 1fr 1.1fr; }
.tfc-image { overflow: hidden; border-radius: var(--border-radius); }
.tfc-img { width: 100%; height: 460px; object-fit: cover; border-radius: var(--border-radius); box-shadow: var(--shadow-md); display: block; transition: transform 0.5s; }
.tfc-image:hover .tfc-img { transform: scale(1.02); }
.tfc-content h2 { font-size: 2rem; margin-bottom: 1rem; }
.tfc-content p { color: var(--text-muted); margin-bottom: 1.5rem; }
.section-tag { display: inline-block; color: var(--accent-gold); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
.feature-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 2rem; }
.feature-list li { display: flex; align-items: center; gap: 10px; font-weight: 500; font-size: 0.95rem; }
.check { color: var(--accent-gold); font-weight: 700; }
.section-divider { border: none; border-top: 1px solid var(--bg-tertiary); margin: 20px 0 60px; }
.service-hub-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-top: 38px;
}
.service-hub-card {
  display: block;
  padding: 24px;
  background: var(--bg-primary);
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius);
  color: inherit;
  text-decoration: none;
  transition: var(--transition);
}
.service-hub-card:hover {
  border-color: var(--accent-gold);
  transform: translateY(-4px);
  box-shadow: var(--shadow-sm);
}
.service-hub-card h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
}
.service-hub-card p {
  color: var(--text-muted);
  font-size: 0.9rem;
  line-height: 1.6;
  margin-bottom: 18px;
}
.service-hub-card span {
  color: var(--accent-gold);
  font-family: var(--font-heading);
  font-size: 0.9rem;
  font-weight: 600;
}

.interior-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
.int-photo { width: 100%; height: 280px; object-fit: cover; border-radius: var(--border-radius); display: block; }

.cta-banner { background: var(--accent-dark); padding: 80px 0; }
.cta-title { color: white; font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin-bottom: 1rem; }
.cta-sub { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 2.5rem; }
.cta-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; }
.btn-outline-dark {
  display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
  font-family: var(--font-heading); font-weight: 500; font-size: 1rem;
  border-radius: var(--border-radius-sm); border: 1.5px solid rgba(255,255,255,0.3); color: white; transition: var(--transition);
}
.btn-outline-dark:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.6); }

@media (max-width: 900px) {
  .tour-full-card, .tour-full-card.reverse { grid-template-columns: 1fr; gap: 30px; }
  .tfc-img { height: 300px; }
  .interior-gallery { grid-template-columns: 1fr 1fr; }
  .service-hub-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .interior-gallery { grid-template-columns: 1fr; }
  .service-hub-grid { grid-template-columns: 1fr; }
}
</style>

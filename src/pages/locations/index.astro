---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import locationsData from '../../data/locations.js';

const title = "Maxi Taxi Service Areas Victoria";
const description = "Find Melbourne and Victorian taxi service areas for maxi cabs, airport transfers, family taxis, wheelchair requests, parcels, events, and schools.";

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.premiummaxicab.com.au" },
    { "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://www.premiummaxicab.com.au/locations" }
  ]
};
---

<Layout title={title} description={description}>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <main>
    <!-- ── PAGE HEADER ── -->
    <section class="page-header">
      <div class="page-header-bg"></div>
      <div class="container page-header-content">
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/">Home</a>
          <span class="sep">›</span>
          <span>Service Areas</span>
        </nav>
        <div class="section-tag">Coverage</div>
        <h1 class="page-title">Victoria <em class="text-gold">Service Areas</em></h1>
        <p class="page-sub">
          Find the right local page for maxi cabs, standard taxi requests, SUV and wagon taxis, airport transfers, baby-seat taxis, wheelchair-accessible requests, parcel delivery, events, schools, and outer Melbourne trips.
        </p>
      </div>
    </section>

    <!-- ── LOCATION GRID ── -->
    <section class="section">
      <div class="container">
        <div class="loc-grid">
          {locationsData.map((loc, i) => (
            <a href={`/locations/${loc.slug}`} class="loc-card reveal" style={`animation-delay:${i * 0.07}s`}>
              <div class="loc-card-inner">
                <div class="loc-header">
                  <div class="loc-icon">📍</div>
                  <div class="loc-postcode">{loc.postcode}</div>
                </div>
                <h2 class="loc-name">{loc.name}</h2>
                <p class="loc-desc">{loc.shortDescription}</p>
                <div class="loc-meta">
                  <span class="loc-poi">🏛 {Array.isArray(loc.poi) ? loc.poi[0] : loc.poi.split(',')[0]}</span>
                  <span class="loc-cta">Book Now →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── WHY CHOOSE US ── -->
    <section class="section section-dark">
      <div class="container text-center">
        <div class="section-tag">Why Book With Us</div>
        <h2 class="section-title" style="color: white;">Built Around <em class="text-gold">Real Local Searches</em></h2>
        <p class="section-sub" style="color: rgba(255,255,255,0.7); max-width: 640px;">
          Each suburb page connects location intent with the actual trip type: airport, family, wheelchair, parcel, student, corporate, event, cruise, group, or regional travel.
        </p>
        <div class="why-grid">
          {[
            { icon: "✈️", title: "Airport Intent", desc: "Pages include route notes, luggage needs, flight details, and airport corridor context." },
            { icon: "♿", title: "Access Notes", desc: "Wheelchair, carer, child-seat, pram, parcel and equipment requirements are treated as booking details." },
            { icon: "🧳", title: "Vehicle Fit", desc: "The site supports standard taxi, SUV, wagon, maxi cab, and specialist request pathways." },
            { icon: "📍", title: "Nearby Coverage", desc: "Suburb pages link nearby areas, popular trip types, corridors, and high-intent booking pages." },
          ].map(item => (
            <div class="why-card">
              <div class="why-icon">{item.icon}</div>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          ))}
        </div>
        <a href="/book" class="btn btn-primary" style="margin-top: 48px;">Book Your Ride Now</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* ── Page Header ─────────────────── */
.page-header {
  position: relative;
  padding: 140px 0 80px;
  overflow: hidden;
  background: var(--accent-dark);
}
.page-header-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 20% 50%, rgba(212,175,55,0.08) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 50%, rgba(212,175,55,0.05) 0%, transparent 60%);
}
.page-header-content {
  position: relative;
  z-index: 2;
  color: white;
}
.breadcrumb {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: rgba(255,255,255,0.5);
  margin-bottom: 1.5rem;
}
.breadcrumb a { color: rgba(255,255,255,0.5); }
.breadcrumb a:hover { color: var(--accent-gold); }
.sep { opacity: 0.5; }
.section-tag {
  display: inline-block;
  color: var(--accent-gold);
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.page-title {
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-style: normal;
  color: white;
  margin-bottom: 1rem;
  line-height: 1.15;
}
.page-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.7);
  max-width: 600px;
}

/* ── Locations Grid ──────────────── */
.loc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}
.loc-card {
  display: block;
  background: var(--bg-primary);
  border: 1px solid var(--bg-tertiary);
  border-radius: var(--border-radius);
  overflow: hidden;
  transition: var(--transition);
  text-decoration: none;
  color: inherit;
}
.loc-card:hover {
  border-color: var(--accent-gold);
  transform: translateY(-6px);
  box-shadow: 0 12px 40px rgba(212,175,55,0.15);
}
.loc-card-inner { padding: 28px; }
.loc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.loc-icon { font-size: 1.6rem; }
.loc-postcode {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent-gold);
  background: rgba(212,175,55,0.1);
  border: 1px solid rgba(212,175,55,0.3);
  border-radius: 100px;
  padding: 4px 10px;
  letter-spacing: 1px;
}
.loc-name {
  font-size: 1.4rem;
  margin-bottom: 10px;
  font-style: normal;
  line-height: 1.2;
}
.loc-desc {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 20px;
}
.loc-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--bg-tertiary);
  padding-top: 16px;
}
.loc-poi {
  font-size: 0.8rem;
  color: var(--text-muted);
}
.loc-cta {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--accent-gold);
  transition: var(--transition);
}
.loc-card:hover .loc-cta {
  letter-spacing: 0.5px;
}

/* ── Section ─────────────────────── */
.section { padding: 100px 0; }
.section-dark {
  background: var(--accent-dark);
}
.section-title {
  font-size: clamp(1.75rem, 3.5vw, 2.6rem);
  margin-bottom: 1rem;
}
.section-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 620px;
  margin: 0 auto 3rem;
}

/* ── Why Grid ────────────────────── */
.why-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 48px;
}
.why-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--border-radius);
  padding: 32px 24px;
  transition: var(--transition);
}
.why-card:hover {
  border-color: rgba(212,175,55,0.4);
  background: rgba(212,175,55,0.04);
}
.why-icon { font-size: 2rem; margin-bottom: 16px; }
.why-card h3 {
  font-size: 1.05rem;
  color: white;
  margin-bottom: 8px;
}
.why-card p {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.6;
}

/* ── Responsive ─────────────────── */
@media (max-width: 1024px) {
  .why-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .page-header { padding: 120px 0 60px; }
  .why-grid { grid-template-columns: repeat(2, 1fr); }
  .loc-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .why-grid { grid-template-columns: 1fr; }
}
</style>
